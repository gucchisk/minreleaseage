{
  "name": "@gucchisk/minreleaseage",
  "version": "0.0.0",
  "description": "Check if each package in package-lock.json has been released for at least N hours",
  "main": "dist/index.js",
  "bin": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test:unit": "tsx --test test.ts",
    "test:e2e": "npm run build && tsx e2e.ts",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gucchisk/minreleaseage.git"
  },
  "author": "gucchisk",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gucchisk/minreleaseage/issues"
  },
  "homepage": "https://github.com/gucchisk/minreleaseage#readme",
  "packageManager": "yarn@4.14.1",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
